import java.util.*;

class Voter {
    int id;
    String name;
    boolean hasVoted;

    Voter(int id, String name) {
        this.id = id;
        this.name = name;
        this.hasVoted = false;
    }
}

public class VotingSystem {
    static ArrayList<Voter> voters = new ArrayList<>();
    static HashMap<String, Integer> votes = new HashMap<>();
    static Scanner sc = new Scanner(System.in);

    public static void main(String[] args) {

        votes.put("A", 0);
        votes.put("B", 0);

        while (true) {
            System.out.println("\n1.Register 2.Vote 3.Results 4.Exit");
            int ch = sc.nextInt();
            sc.nextLine();

            switch (ch) {
                case 1: register(); break;
                case 2: vote(); break;
                case 3: results(); break;
                case 4: return;
            }
        }
    }

    static void register() {
        System.out.print("ID: ");
        int id = sc.nextInt();
        sc.nextLine();

        System.out.print("Name: ");
        String name = sc.nextLine();

        voters.add(new Voter(id, name));
        System.out.println("Registered");
    }

    static void vote() {
        System.out.print("Enter Voter ID: ");
        int id = sc.nextInt();

        for (Voter v : voters) {
            if (v.id == id) {
                if (!v.hasVoted) {
                    System.out.print("Vote (A/B): ");
                    String choice = sc.next().toUpperCase();

                    if (votes.containsKey(choice)) {
                        votes.put(choice, votes.get(choice) + 1);
                        v.hasVoted = true;
                        System.out.println("Vote Casted");
                    } else {
                        System.out.println("Invalid Candidate");
                    }
                } else {
                    System.out.println("Already Voted");
                }
                return;
            }
        }
        System.out.println("Voter Not Found");
    }

    static void results() {
        for (String c : votes.keySet()) {
            System.out.println(c + ": " + votes.get(c));
        }
    }
}
