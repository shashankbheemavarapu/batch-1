import java.util.*;

class Product {
    int id;
    String name;
    int quantity;
    double price;

    Product(int id, String name, int quantity, double price) {
        this.id = id;
        this.name = name;
        this.quantity = quantity;
        this.price = price;
    }
}

public class InventorySystem {
    static ArrayList<Product> list = new ArrayList<>();
    static Scanner sc = new Scanner(System.in);

    public static void main(String[] args) {
        while (true) {
            System.out.println("\n1.Add 2.Update 3.Remove 4.Display 5.Value 6.Exit");
            int ch = sc.nextInt();

            switch (ch) {
                case 1: add(); break;
                case 2: update(); break;
                case 3: remove(); break;
                case 4: display(); break;
                case 5: totalValue(); break;
                case 6: return;
                default: System.out.println("Invalid");
            }
        }
    }

    static Product find(int id) {
        for (Product p : list) {
            if (p.id == id) return p;
        }
        return null;
    }

    static void add() {
        System.out.print("ID: ");
        int id = sc.nextInt();
        sc.nextLine();

        System.out.print("Name: ");
        String name = sc.nextLine();

        System.out.print("Quantity: ");
        int qty = sc.nextInt();

        System.out.print("Price: ");
        double price = sc.nextDouble();

        list.add(new Product(id, name, qty, price));
        System.out.println("Product Added");
    }

    static void update() {
        System.out.print("Enter ID: ");
        int id = sc.nextInt();

        Product p = find(id);
        if (p != null) {
            System.out.print("New Quantity: ");
            p.quantity = sc.nextInt();
            System.out.println("Updated");
        } else {
            System.out.println("Not Found");
        }
    }

    static void remove() {
        System.out.print("Enter ID: ");
        int id = sc.nextInt();

        list.removeIf(p -> p.id == id);
        System.out.println("Removed (if existed)");
    }

    static void display() {
        for (Product p : list) {
            System.out.println(p.id + " " + p.name + " Qty:" + p.quantity + " Price:" + p.price);

            if (p.quantity < 5) {
                System.out.println("⚠ Low Stock Alert!");
            }
        }
    }

    static void totalValue() {
        double total = 0;
        for (Product p : list) {
            total += p.quantity * p.price;
        }
        System.out.println("Total Inventory Value: " + total);
    }
}
